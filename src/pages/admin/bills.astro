---
// src/pages/admin/bills.astro
// Bills & Payments – financial overview and payment recording

import AdminLayout from "../../layouts/AdminLayout.astro";
import { sanityClient } from "../../lib/sanity";
import BillsTable from "../../components/admin/BillsTable";
import { 
      DollarSign, 
      CheckCircle, 
      AlertCircle 
} from 'lucide-react';


// Fetch all bookings with financial fields
const bookings = await sanityClient.fetch(`
  *[_type == "booking"] | order(createdAt desc) {
      _id,
      accountNumber,
      clientName,
      email,
      totalPrice,
      amountPaid,
      paymentStatus,
      eventDate,
      bookingType,
      assignedSpace
      }
`);

// Calculate totals
const totalRevenue = bookings.reduce((sum, b) => sum + (b.totalPrice || 0), 0);
const totalPaid = bookings.reduce((sum, b) => sum + (b.amountPaid || 0), 0);
const totalOutstanding = totalRevenue - totalPaid;
---

<AdminLayout title="Bills & Payments">
  <!-- Summary Cards -->
  <div class="flex gap-3 mb-5">

    <div class="flex-1 min-w-0 bg-white rounded-xl border border-[#e5e7eb] shadow-sm p-3 flex items-center gap-2">
      <div class="p-1.5 rounded-lg bg-[#f3f4f6] text-[#6b7280] shrink-0">
        <DollarSign className="w-3.5 h-3.5" />
      </div>
      <div class="min-w-0">
        <p class="text-[0.55rem] font-semibold uppercase tracking-widest text-[#9ca3af] truncate">Total Revenue</p>
        <p class="text-base font-light text-[#111827] truncate">${totalRevenue.toFixed(2)}</p>
      </div>
    </div>

    <div class="flex-1 min-w-0 bg-white rounded-xl border border-[#e5e7eb] shadow-sm p-3 flex items-center gap-2">
      <div class="p-1.5 rounded-lg bg-emerald-50 text-emerald-600 shrink-0">
        <CheckCircle className="w-3.5 h-3.5" />
      </div>
      <div class="min-w-0">
        <p class="text-[0.55rem] font-semibold uppercase tracking-widest text-[#9ca3af] truncate">Total Paid</p>
        <p class="text-base font-light text-emerald-600 truncate">${totalPaid.toFixed(2)}</p>
      </div>
    </div>

    <div class="flex-1 min-w-0 bg-white rounded-xl border border-[#e5e7eb] shadow-sm p-3 flex items-center gap-2">
      <div class="p-1.5 rounded-lg bg-red-50 text-red-500 shrink-0">
        <AlertCircle className="w-3.5 h-3.5" />
      </div>
      <div class="min-w-0">
        <p class="text-[0.55rem] font-semibold uppercase tracking-widest text-[#9ca3af] truncate">Outstanding</p>
        <p class="text-base font-light text-red-600 truncate">${totalOutstanding.toFixed(2)}</p>
      </div>
    </div>

  </div>

  <!-- Bills Table -->
  <BillsTable client:load initialBookings={bookings} />
</AdminLayout>
