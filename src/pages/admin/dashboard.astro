---
// src/pages/admin/dashboard.astro
// Admin Dashboard – stats, recent bookings

import AdminLayout from "../../layouts/AdminLayout.astro";
import { sanityClient } from "../../lib/sanity";

// Lucide icons
import { DollarSign, CalendarDays, CalendarCheck, QrCode } from "lucide-react";

// ─── Fetch all bookings from Sanity ───
const bookings = await sanityClient.fetch(`
  *[_type == "booking"] | order(createdAt desc) {
    _id, accountNumber, clientName, eventDate, paymentStatus, amountPaid, totalPrice
  }
`);

const totalBookings = bookings.length;
const upcoming = bookings.filter(
  (b: any) => b.eventDate && new Date(b.eventDate) > new Date(),
).length;

// ─── Real revenue: sum of amountPaid across all bookings ───
const totalRevenue = bookings.reduce(
  (sum: number, b: any) => sum + (b.amountPaid || 0), 0
);

// ─── QR scans from D1 (falls back to 0 if DB unavailable) ───
let qrScans = 0;
try {
  const scanData = await sanityClient.fetch(`count(*[_type == "qrScan"])`);
  qrScans = scanData || 0;
} catch (_) {}

---

<AdminLayout title="Dashboard">
  <!-- ===== STATS CARDS ===== -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
    <div class="card p-6 flex items-start gap-4">
      <div class="p-3 rounded-lg bg-[#f3f4f6] text-[#6b7280]">
        <DollarSign class="w-5 h-5" />
      </div>
      <div>
        <p class="text-sm text-[#6b7280] uppercase tracking-wider">Revenue</p>
        <p class="text-2xl font-light">${totalRevenue.toLocaleString()}</p>
      </div>
    </div>

    <div class="card p-6 flex items-start gap-4">
      <div class="p-3 rounded-lg bg-[#f3f4f6] text-[#6b7280]">
        <CalendarDays class="w-5 h-5" />
      </div>
      <div>
        <p class="text-sm text-[#6b7280] uppercase tracking-wider">Bookings</p>
        <p class="text-2xl font-light">{totalBookings}</p>
      </div>
    </div>

    <div class="card p-6 flex items-start gap-4">
      <div class="p-3 rounded-lg bg-[#f3f4f6] text-[#6b7280]">
        <CalendarCheck class="w-5 h-5" />
      </div>
      <div>
        <p class="text-sm text-[#6b7280] uppercase tracking-wider">Upcoming</p>
        <p class="text-2xl font-light">{upcoming}</p>
      </div>
    </div>

    <div class="card p-6 flex items-start gap-4">
      <div class="p-3 rounded-lg bg-[#f3f4f6] text-[#6b7280]">
        <QrCode class="w-5 h-5" />
      </div>
      <div>
        <p class="text-sm text-[#6b7280] uppercase tracking-wider">QR Scans</p>
        <p class="text-2xl font-light">{qrScans}</p>
      </div>
    </div>
  </div>

  <!-- ===== CHARTS (placeholder – uncomment later) ===== -->
  <!--
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="card p-6">
      <h3 class="text-sm uppercase tracking-wider text-[#6b7280] mb-4">Revenue by Month</h3>
      <RevenueChart client:load data={monthlyRevenue} />
    </div>
    <div class="card p-6 flex flex-col items-center">
      <h3 class="text-sm uppercase tracking-wider text-[#6b7280] mb-4">Booking Status</h3>
      <StatusPie client:load />
    </div>
  </div>
  -->

  <!-- ===== RECENT BOOKINGS ===== -->
  <div class="card p-6">
    <h3 class="text-sm uppercase tracking-wider text-[#6b7280] mb-4">
      Recent Bookings
    </h3>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-[#e5e7eb]/60">
          <th class="text-left py-3 font-medium text-[#6b7280]">Account</th>
          <th class="text-left py-3 font-medium text-[#6b7280]">Client</th>
          <th class="text-left py-3 font-medium text-[#6b7280]">Event Date</th>
          <th class="text-left py-3 font-medium text-[#6b7280]">Status</th>
        </tr>
      </thead>
      <tbody>
        {
          bookings.slice(0, 5).map((b: any) => (
            <tr key={b._id} class="border-b border-[#e5e7eb]/30">
              <td class="py-3 font-mono text-sm">{b.accountNumber}</td>
              <td>{b.clientName}</td>
              <td>{new Date(b.eventDate).toLocaleDateString()}</td>
              <td>
                <span
                  class={`px-3 py-1 rounded-full text-xs font-medium ${
                    b.paymentStatus === "paid"
                      ? "badge-paid"
                      : b.paymentStatus === "partial"
                        ? "badge-partial"
                        : "badge-unpaid"
                  }`}
                >
                  {b.paymentStatus || "unpaid"}
                </span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</AdminLayout>
