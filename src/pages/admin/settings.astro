---
// src/pages/admin/settings.astro
// Settings page – brand, colors, fees, contact

import AdminLayout from '../../layouts/AdminLayout.astro';
import SettingsForm from '../../components/admin/SettingsForm';
---

<AdminLayout title="Settings">
      <div class="mb-6">
            <h2 class="text-xl font-light tracking-wide">Site Settings</h2>
            <p class="text-sm text-[#8e8e93]">Manage venue branding, colors, fees, and contact info.</p>
      </div>

      <div class="bg-white rounded-xl border border-[#e5e7eb] shadow-sm p-6">
        <SettingsForm client:load />
      </div>
</AdminLayout>