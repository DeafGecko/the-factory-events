---
// src/pages/admin/edit/[id].astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { sanityClient } from '../../../lib/sanity';
import Card from '../../../components/ui/Card.astro';
import BookingEditForm from '../../../components/admin/BookingEditForm';

const { id } = Astro.params;

const booking = await sanityClient.fetch(`
  *[_type == "booking" && _id == $id][0] {
    _id,
    accountNumber,
    clientName,
    email,
    phone,
    eventDate,
    eventType,
    bookingType,
    assignedSpace,
    spaceType,
    guestCount,
    totalPrice,
    amountPaid,
    paymentStatus,
    notes,
    createdAt
  }
`, { id });

if (!booking) {
  return Astro.redirect('/admin');
}

const formattedEventDate = booking.eventDate
  ? new Date(booking.eventDate).toISOString().slice(0, 16)
  : '';
---

<AdminLayout title="Edit Booking">
  <section>
    <header class="flex flex-wrap items-center justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-light tracking-wide">Edit Booking</h2>
        <p class="text-sm text-[#8e8e93]">{booking.accountNumber} · {booking.clientName}</p>
      </div>
      <a href="/admin" class="inline-block">
        <Button variant="outline">← Back to Bookings</Button>
      </a>
    </header>

    <Card>
      <BookingEditForm client:load booking={booking} formattedEventDate={formattedEventDate} />
    </Card>
  </section>
</AdminLayout>