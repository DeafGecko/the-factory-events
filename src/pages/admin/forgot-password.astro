---
import { sanityClient } from '../../lib/sanity';
let settings;
try {
  settings = await sanityClient.fetch(`*[_type == "settings"][0]`);
} catch { settings = null; }
const primaryColor = settings?.primaryColor || '#A03A3A';
const venueName = settings?.venueName || 'Venue Operations';
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Password · {venueName}</title>
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap" rel="stylesheet" />
  <style define:vars={{ primary: primaryColor }}>
    body { font-family: 'Inter', system-ui, sans-serif; background: #f2f1ef; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; padding: 1rem; }
    .box { background: #fff; padding: 2.5rem 2.8rem; max-width: 420px; width: 100%; border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.08); text-align: center; }
    h1 { font-size: 1.5rem; font-weight: 400; text-transform: uppercase; margin: 0 0 0.25rem 0; }
    .sub { color: #8e8e93; margin-bottom: 1.75rem; }
    .error { color: #b91c1c; background: #fee2e2; padding: 0.5rem; border-radius: 6px; margin-bottom: 1rem; font-size: 0.85rem; }
    .success { color: #065f46; background: #d1fae5; padding: 0.5rem; border-radius: 6px; margin-bottom: 1rem; font-size: 0.85rem; }
    label { display: block; text-align: left; font-size: 0.75rem; font-weight: 500; text-transform: uppercase; color: #555; margin-bottom: 0.25rem; }
    input { width: 100%; border: 1px solid #d0d0d0; padding: 0.75rem 1rem; margin-bottom: 1.25rem; border-radius: 8px; font-size: 0.95rem; background: #fafaf9; box-sizing: border-box; }
    input:focus { outline: none; border-color: var(--primary); background: #fff; }
    button { width: 100%; background: var(--primary); color: white; border: none; padding: 0.8rem; border-radius: 8px; font-size: 0.9rem; text-transform: uppercase; font-weight: 500; cursor: pointer; transition: opacity 0.15s; }
    button:hover { opacity: 0.85; }
    .back-link { margin-top: 1.5rem; font-size: 0.8rem; }
    .back-link a { color: var(--primary); text-decoration: none; }
  </style>
</head>
<body>
  <div class="box">
    <h1>Reset Password</h1>
    <p class="sub">Enter your email and we'll send you a reset link.</p>

    {error && <p class="error">{error}</p>}
    {success && <p class="success">Check your email for a reset link.</p>}

    <form method="POST" action="/api/admin/auth/forgot-password">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" placeholder="admin@venue.com" required />
      <button type="submit">Send Reset Link</button>
    </form>

    <div class="back-link">
      <a href="/admin/login">← Back to login</a>
    </div>
  </div>
</body>
</html>