---
// src/pages/admin/login.astro
const error = Astro.url.searchParams.get('error');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login</title>
  <link rel="stylesheet" href="/styles/global.css" />
  <style>
    body {
      background: #f2f1ef;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      font-family: system-ui, sans-serif;
    }
    .login-box {
      background: white;
      padding: 2rem;
      max-width: 400px;
      width: 100%;
      border: 1px solid #d0d0d0;
      border-radius: 8px;
    }
    h1 {
      font-size: 1.5rem;
      font-weight: 300;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    .error {
      color: #b91c1c;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    input {
      width: 100%;
      border: 1px solid #d0d0d0;
      padding: 0.75rem;
      margin-bottom: 1rem;
      border-radius: 6px;
      font-size: 1rem;
    }
    button {
      width: 100%;
      background: #1a1a1a;
      color: white;
      border: none;
      padding: 0.75rem;
      border-radius: 6px;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      cursor: pointer;
    }
    button:hover {
      background: #333;
    }
  </style>
</head>
<body>
  <div class="login-box">
    <h1>Admin Login</h1>
    {error && <p class="error">Invalid password. Try again.</p>}
    <form method="POST" action="/api/admin/auth">
      <input type="password" name="password" placeholder="Enter admin password" required />
      <button type="submit">Login</button>
    </form>
  </div>
</body>
</html>