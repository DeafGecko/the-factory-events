---
// src/pages/admin/index.astro
// Bookings list – main admin page

import AdminLayout from '../../layouts/AdminLayout.astro';
import { sanityClient } from '../../lib/sanity';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import BookingTable from '../../components/admin/BookingTable';

// Fetch all bookings
const bookings = await sanityClient.fetch(`
  *[_type == "booking"] | order(createdAt desc) {
    _id,
    accountNumber,
    clientName,
    email,
    phone,
    eventDate,
    eventType,
    bookingType,
    assignedSpace,
    spaceType,
    guestCount,
    totalPrice,
    amountPaid,
    paymentStatus,
    notes,
    createdAt
  }
`);
---

<AdminLayout title="Bookings">
  <section>
    <header class="flex flex-wrap items-center justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-light tracking-wide">All Bookings</h2>
        <p class="text-sm text-[#8e8e93]">{bookings.length} total bookings</p>
      </div>
      <a href="/admin/request" class="inline-block">
        <Button variant="primary">+ New Booking</Button>
      </a>
    </header>

    <Card noPadding>
      <BookingTable client:load initialBookings={bookings} />
    </Card>
  </section>
</AdminLayout>