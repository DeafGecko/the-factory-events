---
// src/pages/admin/index.astro
// Bookings list – main admin page

import AdminLayout from '../../layouts/AdminLayout.astro';
import { sanityClient } from '../../lib/sanity';
import BookingTable from '../../components/admin/BookingTable';

// Fetch all bookings
const bookings = await sanityClient.fetch(`
  *[_type == "booking"] | order(createdAt desc) {
    _id,
    accountNumber,
    clientName,
    email,
    phone,
    eventDate,
    eventType,
    bookingType,
    assignedSpace,
    spaceType,
    guestCount,
    totalPrice,
    amountPaid,
    paymentStatus,
    notes,
    createdAt
  }
`);
---

<AdminLayout title="Bookings" subtitle={`${bookings.length} total bookings`}>
  <BookingTable client:load initialBookings={bookings} />
</AdminLayout>