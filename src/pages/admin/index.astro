---
// src/pages/admin/index.astro
// Bookings Management – Full list with search, filter, edit, delete

import AdminLayout from "../../layouts/AdminLayout.astro";
import { sanityClient } from "../../lib/sanity";
import BookingTable from "../../components/admin/BookingTable";

// Fetch all bookings from Sanity
const bookings = await sanityClient.fetch(`
  *[_type == "booking"] | order(createdAt desc) {
    _id,
    accountNumber,
    clientName,
    email,
    phone,
    eventDate,
    eventType,
    guestCount,
    totalPrice,
    amountPaid,
    paymentStatus,
    notes,
    createdAt
  }
`);
---

<AdminLayout title="Bookings Management">
  <div class="mb-6 flex justify-between items-center flex-wrap gap-4">
    <div>
      <h2 class="text-xl font-light tracking-wide">All Bookings</h2>
      <p class="text-sm text-[#8e8e93]">{bookings.length} total bookings</p>
    </div>
    <a
      href="/admin/request"
      class="px-6 py-2.5 rounded-md bg-[#1c1c1e] text-white hover:bg-[#2c2c2e] transition text-sm"
    >
      + New Booking
    </a>
  </div>

  <!-- React component with search, filter, actions -->
  <BookingTable client:load initialBookings={bookings} />
</AdminLayout>
