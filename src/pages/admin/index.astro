---
// src/pages/admin/index.astro
// Bookings list – main admin page

import AdminLayout from '../../layouts/AdminLayout.astro';
import { sanityClient } from '../../lib/sanity';
import BookingTable from '../../components/admin/BookingTable';

// Fetch all bookings
const bookings = await sanityClient.fetch(`
  *[_type == "booking"] | order(createdAt desc) {
    _id,
    accountNumber,
    clientName,
    email,
    phone,
    eventDate,
    eventType,
    bookingType,
    assignedSpace,
    spaceType,
    guestCount,
    totalPrice,
    amountPaid,
    paymentStatus,
    notes,
    createdAt
  }
`);
---

<AdminLayout title="Bookings">
  <section>
    <header class="mb-4">
      <h2 class="text-xl font-light tracking-wide">All Bookings</h2>
      <p class="text-sm text-[#6b7280]">{bookings.length} total bookings</p>
    </header>

    <BookingTable client:load initialBookings={bookings} />
  </section>
</AdminLayout>