---
import Layout from '../layouts/Layout.astro';
import BookingForm from '../components/BookingForm';
---

<Layout title="Book Your Event | The Factory">
  <main class="min-h-screen py-12 bg-gray-50">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold text-center mb-2">Let's Plan Your Event</h1>
      <p class="text-center text-gray-600 mb-8">Fill out the form below and we'll get back to you within 24 hours.</p>
      <BookingForm client:load />
    </div>
  </main>
</Layout>
