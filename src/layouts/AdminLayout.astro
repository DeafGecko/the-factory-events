---
// src/layouts/AdminLayout.astro
// Accessible Swiss‑Industrial Admin Layout
// – High contrast, no shadows, clear focus, responsive

import '../styles/global.css';

import {
  LayoutDashboard,
  Calendar,
  DollarSign,
  Mail,
  Settings,
  LogOut,
  BookOpen,
} from 'lucide-react';

export interface Props {
  title: string;
  settings?: {
    primaryColor?: string;
    secondaryColor?: string;
    accentColor?: string;
    backgroundColor?: string;
    textColor?: string;
    sidebarColor?: string;
    fontFamily?: string;
    logoUrl?: string;
  };
}

const { title, settings } = Astro.props;

// Fallback – accessible, high‑contrast defaults
const defaults = {
  primary: '#A03A3A',
  secondary: '#7A2A2A',        // darker for contrast
  accent: '#D4C4A8',
  background: '#F5F3EF',
  text: '#1A1A1A',             // near‑black for readability
  sidebar: '#1A1816',          // very dark
  font: 'Inter, system-ui, -apple-system, sans-serif',
  logo: '/logo.svg',
};

const c = { ...defaults, ...settings };
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · Event Planner</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap" rel="stylesheet" />

  <style>
    /* ── CSS Variables with fallbacks ── */
    :root {
      --admin-primary: {c.primary};
      --admin-secondary: {c.secondary};
      --admin-accent: {c.accent};
      --admin-bg: {c.background};
      --admin-text: {c.text};
      --admin-sidebar: {c.sidebar};
      --admin-font: {c.font};
      --admin-logo: url('{c.logo}');
    }

    /* ── Base reset ── */
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--admin-font);
      background: var(--admin-bg);
      color: var(--admin-text);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Layout ── */
    .app-wrapper {
      display: flex;
      min-height: 100vh;
      flex: 1;
    }

    /* ── Sidebar – high contrast, no shadows ── */
    .sidebar {
      background: var(--admin-sidebar);
      color: #ffffff;           /* white on dark – strong contrast */
      width: 270px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      margin: 1rem 0 1rem 1rem;
      border-radius: 0;        /* remove rounded corners for cleaner look */
      border: 1px solid rgba(255, 255, 255, 0.1); /* subtle border instead of shadow */
    }

    .sidebar-brand {
      padding: 1.75rem 1.5rem 1.25rem 1.5rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    }

    .sidebar-brand .logo {
      background-image: var(--admin-logo);
      background-size: contain;
      background-repeat: no-repeat;
      background-position: left center;
      width: 140px;
      height: 40px;
      margin-bottom: 0.5rem;
      /* ensure logo has enough contrast – if it's dark, add a white background */
    }

    .sidebar-brand .sub {
      font-size: 0.65rem;
      color: rgba(255, 255, 255, 0.6);
      letter-spacing: 0.8px;
      text-transform: uppercase;
      margin-top: 2px;
    }

    /* ── Navigation ── */
    .sidebar-nav {
      flex: 1;
      padding: 1.25rem 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.7rem 0.9rem;
      border-radius: 4px;
      color: rgba(255, 255, 255, 0.8);   /* high contrast on dark */
      font-size: 0.9rem;
      font-weight: 400;
      text-decoration: none;
      transition: background 0.1s;
      line-height: 1.4;
      /* ensure touch target ≥ 44px */
      min-height: 44px;
    }

    .sidebar-nav a:hover,
    .sidebar-nav a:focus-visible {
      background: rgba(255, 255, 255, 0.12);
      color: #ffffff;
      outline: 2px solid #ffffff;
      outline-offset: -2px;
    }

    .sidebar-nav a.active {
      background: rgba(255, 255, 255, 0.1);
      color: #ffffff;
      font-weight: 500;
      border-left: 3px solid var(--admin-primary);
    }

    .sidebar-nav a .icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
    }

    .sidebar-nav hr {
      border: none;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      margin: 0.5rem 0.75rem;
    }

    .sidebar-footer {
      padding: 1rem 1.5rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      font-size: 0.65rem;
      color: rgba(255, 255, 255, 0.4);
      text-align: center;
      letter-spacing: 0.3px;
    }

    /* ── Main content ── */
    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: 1.5rem 2rem 0 2rem;
      overflow-x: auto;
      min-width: 0;
    }

    .main-content-inner { flex: 1; }

    /* ── Header ── */
    .page-header {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 1.25rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
      margin-bottom: 1.5rem;
      gap: 0.75rem;
    }

    .page-header h1 {
      font-size: 1.4rem;
      font-weight: 400;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--admin-text);
      margin: 0;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .user-badge {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      color: var(--admin-text);
    }

    .user-badge .avatar {
      background: var(--admin-primary);
      color: #fff;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .logout-link {
      font-size: 0.8rem;
      color: var(--admin-text);
      text-decoration: underline;
      text-underline-offset: 2px;
      transition: color 0.15s;
    }
    .logout-link:hover,
    .logout-link:focus-visible {
      color: var(--admin-primary);
    }

    /* ── Footer ── */
    .app-footer {
      margin-top: auto;
      padding: 1rem 0;
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      font-size: 0.75rem;
      color: var(--admin-text);
      gap: 0.5rem;
    }

    .app-footer a {
      color: var(--admin-text);
      text-decoration: underline;
    }
    .app-footer a:hover {
      color: var(--admin-primary);
    }

    /* ── High Contrast mode (system) ── */
    @media (prefers-contrast: high) {
      :root {
        --admin-bg: #ffffff;
        --admin-text: #000000;
        --admin-primary: #000000;
        --admin-secondary: #333333;
        --admin-sidebar: #000000;
      }
      .sidebar {
        border-color: #ffffff;
      }
      .sidebar-nav a {
        color: #ffffff;
        border: 1px solid transparent;
      }
      .sidebar-nav a:hover,
      .sidebar-nav a:focus-visible {
        background: #ffffff;
        color: #000000;
        border-color: #000000;
      }
      .sidebar-nav a.active {
        background: #ffffff;
        color: #000000;
        border-left-color: #000000;
        border-left-width: 4px;
      }
      .page-header,
      .app-footer {
        border-color: #000000;
      }
      .card {
        border: 2px solid #000000;
        background: #ffffff;
      }
    }

    /* ── Cards and badges (no shadows) ── */
    .card {
      background: #ffffff;
      border: 1px solid var(--admin-accent);
      border-radius: 4px;
      padding: 1rem;
    }

    .badge-paid {
      background: #d4edda;
      color: #155724;
    }
    .badge-partial {
      background: #fff3cd;
      color: #856404;
    }
    .badge-unpaid {
      background: #f8d7da;
      color: #721c24;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .sidebar {
        width: 100%;
        margin: 0.5rem;
        border-radius: 0;
      }
      .app-wrapper {
        flex-direction: column;
      }
      .main-content {
        padding: 1rem;
      }
      .page-header {
        flex-direction: column;
        align-items: stretch;
      }
      .page-header .header-actions {
        justify-content: flex-end;
      }
    }
  </style>
</head>
<body>
  <div class="app-wrapper">

    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar" role="navigation" aria-label="Main navigation">
      <div class="sidebar-brand">
        <div class="logo" role="img" aria-label="Event Planner logo"></div>
        <div class="sub">Admin Panel</div>
      </div>

      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="active">
          <LayoutDashboard class="icon" aria-hidden="true" />
          Dashboard
        </a>
        <a href="/admin">
          <BookOpen class="icon" aria-hidden="true" />
          Bookings
        </a>
        <a href="/admin/calendar">
          <Calendar class="icon" aria-hidden="true" />
          Calendar
        </a>
        <a href="/admin/bills">
          <DollarSign class="icon" aria-hidden="true" />
          Bills
        </a>
        <a href="/admin/newsletter">
          <Mail class="icon" aria-hidden="true" />
          Newsletter
        </a>
        <a href="/admin/settings">
          <Settings class="icon" aria-hidden="true" />
          Settings
        </a>
        <hr aria-hidden="true" />
        <a href="/admin/logout" style="color:rgba(255,255,255,0.6);">
          <LogOut class="icon" aria-hidden="true" />
          Logout
        </a>
      </nav>

      <div class="sidebar-footer">
        Event Planner · v1.0
      </div>
    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="main-content">
      <div class="main-content-inner">
        <header class="page-header">
          <h1>{title}</h1>
          <div class="header-actions">
            <span class="user-badge">
              <span class="avatar" aria-hidden="true">A</span>
              Admin
            </span>
            <a href="/admin/logout" class="logout-link">Logout</a>
          </div>
        </header>

        <slot />
      </div>

      <footer class="app-footer">
        <span>&copy; {currentYear} <a href="/">Event Planner</a></span>
        <span>
          Built with <a href="https://astro.build" target="_blank">Astro</a> ·
          <a href="https://cloudflare.com" target="_blank">Cloudflare</a>
        </span>
      </footer>
    </div>
  </div>
</body>
</html>