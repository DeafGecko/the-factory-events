---
// src/layouts/AdminLayout.astro
// Polished Swiss‑Industrial Admin Layout

import '../styles/global.css';

export interface Props {
  title: string;
  settings?: {
    primaryColor?: string;
    secondaryColor?: string;
    accentColor?: string;
    backgroundColor?: string;
    textColor?: string;
    sidebarColor?: string;
    fontFamily?: string;
    logoUrl?: string;
  };
}

const { title, settings } = Astro.props;

const defaults = {
  primary: '#A03A3A',
  secondary: '#B05040',
  accent: '#D4C4A8',
  background: '#F5F3EF',
  text: '#2A1A0E',
  sidebar: '#1A1816',
  font: 'Inter, system-ui, -apple-system, sans-serif',
  logo: '/logo.svg',
};

const c = { ...defaults, ...settings };
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · Event Planner</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap" rel="stylesheet" />

  <style>
    /* Custom overrides and fine‑tuning */
    :root {
      --admin-primary: {c.primary};
      --admin-secondary: {c.secondary};
      --admin-accent: {c.accent};
      --admin-bg: {c.background};
      --admin-text: {c.text};
      --admin-sidebar: {c.sidebar};
      --admin-font: {c.font};
      --admin-logo: url('{c.logo}');
    }

    body {
      font-family: var(--admin-font);
      background: var(--admin-bg);
      color: var(--admin-text);
      -webkit-font-smoothing: antialiased;
    }

    .sidebar {
      background: var(--admin-sidebar);
      color: #f5f3ef;
      width: 260px;
    }

    .sidebar a {
      color: rgba(255,255,255,0.6);
      transition: all 0.15s;
    }
    .sidebar a:hover {
      background: rgba(255,255,255,0.06);
      color: #fff;
    }
    .sidebar a.active {
      background: rgba(255,255,255,0.08);
      color: #fff;
      font-weight: 500;
    }

    .logo {
      background-image: var(--admin-logo);
      background-size: contain;
      background-repeat: no-repeat;
      background-position: left center;
      width: 120px;
      height: 36px;
    }

    .avatar {
      background: var(--admin-primary);
      color: #fff;
      width: 30px;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .badge-paid {
      background: #d4edda;
      color: #155724;
    }
    .badge-partial {
      background: #fff3cd;
      color: #856404;
    }
    .badge-unpaid {
      background: #f8d7da;
      color: #721c24;
    }
  </style>
</head>
<body>
  <div class="flex min-h-screen">

    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar flex flex-col flex-shrink-0 m-4 rounded-xl shadow-sm">
      <div class="p-5 border-b border-white/10">
        <div class="logo"></div>
        <h2 class="mt-3 text-sm font-light tracking-wider uppercase">Event Planner</h2>
        <p class="text-[0.6rem] text-white/30 uppercase tracking-wider">Admin Panel</p>
      </div>

      <nav class="flex-1 p-4 space-y-0.5 text-sm">
        <a href="/admin/dashboard" class="active flex items-center gap-3 px-4 py-2.5 rounded-md">
          <span class="text-base">📊</span> Dashboard
        </a>
        <a href="/admin" class="flex items-center gap-3 px-4 py-2.5 rounded-md">
          <span class="text-base">📋</span> Bookings
        </a>
        <a href="/admin/calendar" class="flex items-center gap-3 px-4 py-2.5 rounded-md">
          <span class="text-base">📅</span> Calendar
        </a>
        <a href="/admin/bills" class="flex items-center gap-3 px-4 py-2.5 rounded-md">
          <span class="text-base">💰</span> Bills
        </a>
        <a href="/admin/newsletter" class="flex items-center gap-3 px-4 py-2.5 rounded-md">
          <span class="text-base">📧</span> Newsletter
        </a>
        <a href="/admin/settings" class="flex items-center gap-3 px-4 py-2.5 rounded-md">
          <span class="text-base">⚙️</span> Settings
        </a>
        <hr class="border-white/10 my-2" />
        <a href="/admin/logout" class="flex items-center gap-3 px-4 py-2.5 rounded-md text-white/30 hover:text-white/60">
          <span class="text-base">🚪</span> Logout
        </a>
      </nav>

      <div class="p-4 border-t border-white/10 text-[0.6rem] text-white/20 text-center">
        Event Planner · v1.0
      </div>
    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="flex-1 flex flex-col p-6 md:p-8 overflow-x-auto">
      <div class="flex-1">
        <!-- Header -->
        <header class="flex flex-wrap items-center justify-between pb-4 border-b border-[#e8e4dc]/40 mb-6">
          <h1 class="text-xl md:text-2xl font-light tracking-wider uppercase">{title}</h1>
          <div class="flex items-center gap-4">
            <span class="flex items-center gap-2 text-sm text-[#8e8e93]">
              <span class="avatar">A</span>
              Admin
            </span>
            <a href="/admin/logout" class="text-sm text-[#8e8e93] hover:text-[#1c1c1e] transition">Logout</a>
          </div>
        </header>

        <!-- Page Content -->
        <slot />
      </div>

      <!-- Footer -->
      <footer class="pt-4 mt-6 border-t border-[#e8e4dc]/40 text-xs text-[#b0a898] flex flex-wrap justify-between">
        <span>&copy; {currentYear} <a href="/" class="hover:text-[#1c1c1e] transition">Event Planner</a></span>
        <span>
          Built with <a href="https://astro.build" target="_blank" class="hover:text-[#1c1c1e] transition">Astro</a> ·
          <a href="https://cloudflare.com" target="_blank" class="hover:text-[#1c1c1e] transition">Cloudflare</a>
        </span>
      </footer>
    </div>
  </div>
</body>
</html>