---
// src/layouts/AdminLayout.astro
// Complete Admin Layout – dynamic branding from Settings

import '../styles/global.css';
import { sanityClient } from '../lib/sanity';

import {
  LayoutDashboard,
  Calendar,
  DollarSign,
  Settings,
  LogOut,
  BookOpen,
  LayoutGrid,
  Users,
  Building2,
  Briefcase,
  QrCode,
  UserCog,
} from 'lucide-react';

export interface Props {
  title: string;
}

const { title } = Astro.props;

// ── Fetch settings with error handling ──
let settings;
try {
  settings = await sanityClient.fetch(`*[_type == "settings"][0]`);
} catch (error) {
  console.error('❌ Failed to fetch settings:', error);
  settings = null;
}

// ── Default settings values ──
const defaults = {
  primary: '#333333',      // Dark gray
  secondary: '#555555',    // Medium gray
  accent: '#999999',       // Light gray
  background: '#F5F5F5',   // Very light gray (almost white)
  text: '#111111',         // Near black
  sidebar: '#222222',      // Dark gray (sidebar)
  sidebarText: '#ffffff',  // White (sidebar text)
  font: 'Inter, system-ui, -apple-system, sans-serif',
  logo: '/logo.svg',
  venueName: 'Venue Operations',
};

// ── Merge settings with defaults ──
const c = {
  ...defaults,
  primary: settings?.primaryColor || defaults.primary,
  secondary: settings?.secondaryColor || defaults.secondary,
  accent: settings?.accentColor || defaults.accent,
  background: settings?.backgroundColor || defaults.background,
  text: settings?.textColor || defaults.text,
  sidebar: settings?.sidebarColor || defaults.sidebar,
  sidebarText: settings?.sidebarTextColor || defaults.sidebarText,
  avatar: settings?.adminAvatar || null,
  font: settings?.fontFamily || defaults.font,
  logo: settings?.logo?.asset?.url || defaults.logo,
  venueName: settings?.venueName || defaults.venueName,
};

const currentYear = new Date().getFullYear();

// ── Navigation ──
const navItems = [
  { href: '/admin/dashboard', icon: LayoutDashboard, label: 'Dashboard' },
  { href: '/admin', icon: BookOpen, label: 'Bookings' },
  { href: '/admin/calendar', icon: Calendar, label: 'Calendar' },
  { href: '/admin/bills', icon: DollarSign, label: 'Bills' },
  { href: '/admin/spaces', icon: LayoutGrid, label: 'Spaces' },
  { href: '/admin/clients', icon: Users, label: 'Clients' },
  { href: '/admin/vendors', icon: Briefcase, label: 'Vendors' },
  { href: '/admin/qr-scans', icon: QrCode, label: 'QR Scans' },
  { href: '/admin/tenants', icon: Building2, label: 'Tenants' },
];
---

<!DOCTYPE html>
<html lang="en" class={settings?.themePreference === 'dark' ? 'dark' : ''}>
<head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{title} · {c.venueName}</title>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap" rel="stylesheet" />
      <link rel="stylesheet" href="/styles/global.css" />

<Fragment set:html={`<style>
    :root {
      --admin-primary: ${c.primary};
      --admin-secondary: ${c.secondary};
      --admin-accent: ${c.accent};
      --admin-bg: ${c.background};
      --admin-text: ${c.text};
      --admin-sidebar: ${c.sidebar};
      --admin-sidebar-text: ${c.sidebarText};
      --admin-font: ${c.font};
      --admin-border: color-mix(in srgb, ${c.text} 12%, transparent);
      --admin-muted: color-mix(in srgb, ${c.text} 45%, transparent);
    }
  </style>`} />

<style is:global>
    body {
      font-family: var(--admin-font);
      background: var(--admin-bg);
      color: var(--admin-text);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .sidebar {
      background: var(--admin-sidebar) !important;
      color: var(--admin-sidebar-text) !important;
    }

    .sidebar a {
      color: color-mix(in srgb, var(--admin-sidebar-text) 70%, transparent);
    }

    .sidebar a:hover {
      background: color-mix(in srgb, var(--admin-sidebar-text) 8%, transparent);
      color: var(--admin-sidebar-text);
    }

    .sidebar a.active {
      background: color-mix(in srgb, var(--admin-sidebar-text) 12%, transparent);
      color: var(--admin-sidebar-text);
      font-weight: 500;
      border-left: 3px solid var(--admin-primary);
    }

    .sidebar-muted {
      color: color-mix(in srgb, var(--admin-sidebar-text) 45%, transparent);
    }

    .sidebar-border-top {
      border-top: 1px solid color-mix(in srgb, var(--admin-sidebar-text) 12%, transparent);
    }

    .logo {
      width: 140px;
      height: 40px;
      background-size: contain;
      background-repeat: no-repeat;
      background-position: left center;
    }

    @media (prefers-contrast: high) {
      :root {
        --admin-bg: #ffffff;
        --admin-text: #000000;
        --admin-primary: #000000;
      }
    }

    html.dark {
      --admin-bg: #1c1c1e;
      --admin-text: #e5e7eb;
      --admin-accent: #374151;
    }

    .main-header {
      border-bottom: 1px solid var(--admin-border);
    }

    .main-footer {
      border-top: 1px solid var(--admin-border);
      color: var(--admin-muted);
    }

    .admin-muted {
      color: var(--admin-muted);
    }

    .admin-avatar {
      background: var(--admin-primary);
    }

    .content-scroll {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      padding-bottom: 1rem;
      min-height: 0;
    }

    .content-inner {
      flex: 1;
    }

    /* ── Mobile sidebar drawer ── */
    .sidebar-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      z-index: 40;
    }
    .sidebar-backdrop.open { display: block; }

    .mobile-topbar {
      display: none;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      background: var(--admin-sidebar);
      color: #fff;
      position: sticky;
      top: 0;
      z-index: 30;
    }

    .hamburger {
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      color: var(--admin-sidebar-text, #fff);
      line-height: 0;
    }

    @media (max-width: 1023px) {
      .mobile-topbar { display: flex; }

      aside.sidebar {
        position: fixed !important;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 50;
        margin: 0 !important;
        border-radius: 0 !important;
        transform: translateX(-100%);
        transition: transform 0.25s ease;
        width: 18rem !important;
      }

      aside.sidebar.open {
        transform: translateX(0);
      }

      .desktop-layout {
        flex-direction: column;
        height: calc(100vh - 3rem);
      }
    }

    @media (min-width: 1024px) {
      .desktop-layout { flex-direction: row; }
    }

    .btn-primary {
      background: var(--admin-primary) !important;
      color: #fff !important;
      transition: opacity 0.15s;
    }
    .btn-primary:hover {
      opacity: 0.85;
    }

    .ring-primary:focus {
      outline: none;
      box-shadow: 0 0 0 1px var(--admin-primary);
    }
  </style>
</head>
<body>

  <!-- ===== MOBILE TOPBAR ===== -->
  <div class="mobile-topbar">
    <button class="hamburger" id="menu-open" aria-label="Open menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
    <span class="text-sm font-medium tracking-wider uppercase">{c.venueName}</span>
    {c.avatar
      ? <img src={c.avatar} alt="Admin" class="w-8 h-8 rounded-full object-cover" />
      : <span class="w-8 h-8 rounded-full text-white flex items-center justify-center text-sm font-semibold admin-avatar">A</span>
    }
  </div>

<!-- ===== BACKDROP ===== -->
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

  <div class="flex h-screen overflow-hidden desktop-layout">

<!-- ===== SIDEBAR ===== -->
    <aside class="sidebar w-60 shrink-0 m-4 rounded-lg flex flex-col overflow-hidden" style="display: flex !important;">
      <header class="px-5 pt-5 pb-2 border-b border-white/10 shrink-0">
        <div class="flex items-center justify-between mb-1">
          <img src={c.logo} alt={c.venueName} class="h-9 w-auto max-w-30 object-contain" />
          <button class="hamburger lg:hidden" id="menu-close" aria-label="Close menu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <p class="text-xs mt-1 tracking-wider sidebar-muted">Admin Panel</p>
      </header>

      <nav class="flex-1 p-3 overflow-y-auto" aria-label="Main navigation">
        <ul class="space-y-0.5">
          {navItems.map(({ href, icon: Icon, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'flex items-center gap-3 px-4 py-2.5 rounded-md text-sm transition',
                  Astro.url.pathname === href ? 'active' : ''
                ]}
              >
                <Icon className="w-5 h-5 shrink-0" aria-hidden="true" />
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>


      <footer class="p-4 sidebar-border-top shrink-0 space-y-1">

<!-- Settings -->
          <a
          href="/admin/settings"
          class:list={[
            'flex items-center gap-3 px-4 py-2.5 rounded-md text-sm transition',
            Astro.url.pathname === '/admin/settings' ? 'active' : ''
          ]}
        >
          <Settings className="w-5 h-5 shrink-0" aria-hidden="true" />
          Settings
        </a>

<!-- Login Management -->
        <a
          href="/admin/login-management"
          class:list={[
            'flex items-center gap-2 px-3 py-2 rounded-md text-xs text-white/70 hover:text-white hover:bg-white/10 transition',
            Astro.url.pathname === '/admin/login-management' ? 'active' : ''
          ]}
        >
          <UserCog className="w-4 h-4 shrink-0" aria-hidden="true" />
          Login Management
        </a>

<!-- Logout -->
        <a
          href="/admin/logout"
          class="flex items-center gap-3 px-4 py-2.5 rounded-md text-sm transition sidebar-muted"
        >
          <LogOut className="w-5 h-5 shrink-0" aria-hidden="true" />
          Logout
        </a>
        <p class="text-xs text-left pt-2 ml-3.5 sidebar-border-top mt-2 sidebar-muted">
          v1.0 · {currentYear}
        </p>
      </footer>
    </aside>

<!-- ===== MAIN CONTENT ===== -->
    <main class="flex-1 flex flex-col p-6 overflow-hidden" id="main-content">
      <header class="main-header shrink-0 pb-4 mb-6">
        <div class="flex items-center justify-between">
          <h1 class="text-2xl font-light tracking-wider uppercase">{title}</h1>
          <div class="hidden lg:flex items-center gap-4">
            <span class="flex items-center gap-2 text-sm">
              {c.avatar
                ? <img src={c.avatar} alt="Admin" class="w-8 h-8 rounded-full object-cover" />
                : <span class="w-8 h-8 rounded-full text-white flex items-center justify-center text-sm font-semibold uppercase admin-avatar">A</span>
              }
              <span class="admin-muted">Admin</span>
            </span>
            <a href="/admin/logout" class="text-sm admin-muted hover:opacity-80 transition">Logout</a>
          </div>
        </div>
      </header>

      <div class="content-scroll">
        <div class="content-inner">
          <slot />
        </div>

<!-- ===== FOOTER ===== -->       
        <footer class="main-footer shrink-0 pt-4 mt-6 text-xs flex flex-wrap justify-between gap-2">
          <span>&copy; {currentYear} <a href="/" class="hover:opacity-80 transition">{c.venueName}</a></span>
          <span>
            Built with <a href="https://astro.build" target="_blank" class="hover:opacity-80 transition">Astro</a> ·
            <a href="https://react.dev" target="_blank" class="hover:opacity-80 transition">React</a> ·
            <a href="https://cloudflare.com" target="_blank" class="hover:opacity-80 transition">Cloudflare</a>
          </span>
        </footer>
      </div>
    </main>

  </div>
  <script>
    const sidebar = document.querySelector('aside.sidebar');
    const backdrop = document.getElementById('sidebar-backdrop');
    const openBtn = document.getElementById('menu-open');
    const closeBtn = document.getElementById('menu-close');

    function openMenu() {
      sidebar?.classList.add('open');
      backdrop?.classList.add('open');
    }
    function closeMenu() {
      sidebar?.classList.remove('open');
      backdrop?.classList.remove('open');
    }

    openBtn?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);
  </script>
</body>
</html>