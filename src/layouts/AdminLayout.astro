---
// src/layouts/AdminLayout.astro
// Accessible Swiss‑Industrial Admin Layout
// – High contrast, no shadows, clear focus, responsive

import '../styles/global.css';

// Icons from lucide-react
import {
      LayoutDashboard,
      Calendar,
      DollarSign,
      Mail,
      Settings,
      LogOut,
      BookOpen,
      LayoutGrid,
} from 'lucide-react';

// Props interface
export interface Props {
      title: string;
      settings?: {
            primaryColor?: string;
            secondaryColor?: string;
            accentColor?: string;
            backgroundColor?: string;
            textColor?: string;
            sidebarColor?: string;
            fontFamily?: string;
            logoUrl?: string;
      };
}

// Destructure props
const { title, settings } = Astro.props;

// Fallback – accessible, high‑contrast defaults
const defaults = {
      primary: '#A03A3A',
      secondary: '#7A2A2A',        // darker for contrast
      accent: '#D4C4A8',
      background: '#F5F3EF',
      text: '#1A1A1A',             // near‑black for readability
      sidebar: '#1A1816',          // very dark
      font: 'Inter, system-ui, -apple-system, sans-serif',
      logo: '/logo.svg',
};

const c = { ...defaults, ...settings };
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{title} · Event Planner</title>
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap" rel="stylesheet" />

      <style>
/* ── CSS Variables ── */
      :root {
            --admin-primary: {c.primary};
            --admin-secondary: {c.secondary};
            --admin-accent: {c.accent};
            --admin-bg: {c.background};
            --admin-text: {c.text};
            --admin-sidebar: {c.sidebar};
            --admin-font: {c.font};
            --admin-logo: url('{c.logo}');
      }

/* ── Base Reset ── */
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
            font-family: var(--admin-font);
            background: var(--admin-bg);
            color: var(--admin-text);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            height: 100vh;
            overflow:hidden;
            margin: 0;
            padding: 0;
      }

/* ── Layout ── */
      .app-wrapper {
            display: flex;
            height: 100vh;          
            overflow: hidden;       /* Prevent whole page scroll */
      }

/* ── Sidebar – high contrast, no shadows ── */
      .sidebar {
            background: var(--admin-sidebar);
            color: #ffffff;
            width: 220px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            margin: 1rem 0 1rem 1rem;
            border: 2px solid rgba(255, 255, 255, 0.15);
            border-radius: 12px;
            padding: 0;
            height: calc(100% - 2rem);
            overflow-y: auto;
      }

      .sidebar-brand {
            padding: 0.85rem 1.5rem 0.75rem 1.5rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }      

      .sidebar-brand .logo {
            background-image: var(--admin-logo);
            background-size: contain;
            background-repeat: no-repeat;
            background-position: left center;
            width: 140px;
            height: 40px;
            margin-bottom: 0.5rem;
            }

            .sidebar-brand .sub {
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.6);
            letter-spacing: 0.8px;
            text-transform: uppercase;
            margin-top: 2px;
      }

/* ── Navigation ── */
      .sidebar-nav {
            flex: 1;
            padding: 1.25rem 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
      }

      .sidebar-nav a,
      .sidebar-bottom a {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.7rem 0.9rem;
            border-radius: 6px;
            color: rgba(255, 255, 255, 0.8);   /* high contrast on dark */
            font-size: 0.9rem;
            font-weight: 400;
            text-decoration: none;
            transition: background 0.1s;
            min-height: 44px;
      }

      .sidebar-nav a:hover,
      .sidebar-bottom a:hover {
            background: rgba(255, 255, 255, 0.12);
            color: #ffffff;
      }

      .sidebar-nav a.active,
      .sidebar-bottom a.active {
            background: rgba(255, 255, 255, 0.1);
            color: #ffffff;
            font-weight: 500;
            border-left: 3px solid var(--admin-primary);
      }

      .sidebar-nav a .icon,
      .sidebar-bottom a .icon {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
      }

      .sidebar-nav hr {
            border: none;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin: 0.5rem 0.75rem;
      }

      .sidebar-bottom {
            padding: 0.75rem 0.75rem 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
      }

      .sidebar-bottom hr {
            border: none;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin: 0 0.75rem 0.5rem;
      }

      .sidebar-bottom a.logout {
            color: rgba(255, 255, 255, 0.6);
      }

      .sidebar-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.4);
            text-align: center;
            letter-spacing: 0.3px;
      }

/* ── Main content – scrollable ── */
      .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 1.5rem 2rem 0 2rem;
            overflow-y: hidden;      /* no scroll on the wrapper*/
            min-height: 0;         /* Flex override to allow shrinking */
            height: 100vh;         /* Ensure it fills the parent */
      }

/* ── Header ── stay fixed ── */
      .page-header {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.08);
            margin-bottom: 1.5rem;
            gap: 0.75rem;
            flex-shrink: 0;
      }

      .page-header h1 {
            font-size: 1.4rem;
            font-weight: 400;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--admin-text);
            margin: 0;
      }

      .header-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
      }

      .user-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            color: var(--admin-text);
      }

      .user-badge .avatar {
            background: var(--admin-primary);
            color: #fff;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
      }

      .logout-link {
            font-size: 0.8rem;
            color: var(--admin-text);
            text-decoration: underline;
            text-underline-offset: 2px;
            transition: color 0.15s;
      }
      .logout-link:hover,
      .logout-link:focus-visible {
            color: var(--admin-primary);
      }

/* ── Scrollable content area ── */
      .content-scroll {
            flex: 1;                     /* Takes remaining space */
            overflow-y: auto;            /* Enables scrolling */
            display: flex;
            flex-direction: column;
            padding-bottom: 1rem;
            min-height: 0;               /* Important: allows flex child to shrink */
      }

      .content-inner {
            flex: 1;
      }

/* ── Footer ── */
      .app-footer {
            flex-shrink: 0;
            padding: 1rem 0;
            border-top: 1px solid rgba(0, 0, 0, 0.08);
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            font-size: 0.55rem;
            color: var(--admin-text);
            gap: 0.5rem;
            margin-top: 1rem;
      }

      .app-footer a {
            color: var(--admin-text);
            text-decoration: underline;
      }
      .app-footer a:hover {
            color: var(--admin-primary);
      }

/* ── High Contrast mode ── */
      @media (prefers-contrast: high) {
      :root {
            --admin-bg: #ffffff;
            --admin-text: #000000;
            --admin-primary: #000000;
            --admin-secondary: #333333;
            --admin-sidebar: #000000;
      }
      .sidebar {
            border-color: #ffffff;
            border-width: 3px;    /* increase border width for high contrast mode */
      }
      .sidebar-nav a {
            color: #ffffff;
            border: 1px solid transparent;
      }
      .sidebar-nav a:hover,
      .sidebar-nav a:focus-visible {
            background: #ffffff;
            color: #000000;
            border-color: #000000;
      }
      .sidebar-nav a.active {
            background: #ffffff;
            color: #000000;
            border-left-color: #000000;
            border-left-width: 4px;
      }
      .page-header,
      .app-footer {
            border-color: #000000;
      }
      .card {
            border: 2px solid #000000;
            background: #ffffff;
      }

/* ── Cards and badges ── */
      .card {
            background: #ffffff;                  
            border: 1px solid var(--admin-accent);
            border-radius: 4px;
            padding: 1rem;
      }

      .badge-paid {
            background: #d4edda;
            color: #155724;
      }
      .badge-partial {
            background: #fff3cd;
            color: #856404;
      }
      .badge-unpaid {
            background: #f8d7da;
            color: #721c24;
      }
      }
/* ── Responsive ── */
      @media (max-width: 768px) {
      .sidebar {
            width: 100%;
            margin: 0.5rem;
            border-radius: 8px;
            height: auto;
            max-height: 50vh;
      }
      .app-wrapper {
            flex-direction: column;
            height:100vh;
            overflow: hidden;
      }
      .main-content {
            padding: 0.5rem 0 0 0;
            height: 100vh;
      }
      .page-header {
            flex-direction: column;
            align-items: stretch;
      }
      .page-header .header-actions {
            justify-content: flex-end;
      }
      .content-scroll {
            margin-right: 0;
      }     
      }
</style>

</head>
<body>
      <div class="app-wrapper">

<!--  SIDEBAR -->
      <aside class="sidebar" style="display: flex !important; background: rgb(138, 0, 0.7) !important; color: white !important;">
            <div class="sidebar-brand">
                  <div class="logo" role="img" aria-label="Event Planner logo"></div>
                  <div class="sub">Admin Panel</div>
            </div>

            <nav class="sidebar-nav">
                  <a href="/admin/dashboard" class:list={['flex items-center gap-3 px-4 py-2.5 rounded-md', Astro.url.pathname === '/admin/dashboard' ? 'active' : '']}
                  >
                        <LayoutDashboard className="icon" aria-hidden="true" />
                        Dashboard
                  </a>
                  <a href="/admin" class:list={['flex items-center gap-3 px-4 py-2.5 rounded-md', Astro.url.pathname === '/admin' ? 'active' : '']}
                  >
                        <BookOpen className="icon" aria-hidden="true" />
                        Bookings
                  </a>
                  <a href="/admin/calendar" class:list={['flex items-center gap-3 px-4 py-2.5 rounded-md', Astro.url.pathname === '/admin/calendar' ? 'active' : '']}
                  >
                        <Calendar className="icon" aria-hidden="true" />
                        Calendar
                  </a>
                  <a href="/admin/bills" class:list={['flex items-center gap-3 px-4 py-2.5 rounded-md', Astro.url.pathname === '/admin/bills' ? 'active' : '']}
                  >
                        <DollarSign className="icon" aria-hidden="true" />
                        Bills
                  </a>
                  <!-- Newsletter link removed -->
            </nav>

            <div class="sidebar-bottom">
                  <hr aria-hidden="true" />
                  <a href="/admin/spaces" class:list={['flex items-center gap-3 px-4 py-2.5 rounded-md', Astro.url.pathname === '/admin/spaces' ? 'active' : '']}
                  >
                        <LayoutGrid className="icon" aria-hidden="true" />
                              Spaces
                  </a>
                  <a href="/admin/settings" class:list={['flex items-center gap-3 px-4 py-2.5 rounded-md', Astro.url.pathname === '/admin/settings' ? 'active' : '']}
                  >
                        <Settings className="icon" aria-hidden="true" />
                              Settings
                  </a>
                  <a href="/admin/logout" class:list={['flex items-center gap-3 px-4 py-2.5 rounded-md', Astro.url.pathname === '/admin/logout' ? 'active' : '']}
                  >
                        <LogOut className="icon" aria-hidden="true" />
                              Logout
                  </a>
            </div>
      </aside>

<!-- ===== MAIN CONTENT ===== -->
      <div class="main-content">
            <div class="main-content-inner">
                  <header class="page-header">
                        <h1>{title}</h1>
                        <div class="header-actions">
                              <span class="user-badge">
                              <span class="avatar" aria-hidden="true">A</span>
                              Admin
                              </span>
                              <a href="/admin/logout" class="logout-link">Logout</a>
                        </div>
                  </header>

                  <slot />
            </div>

                  <footer class="app-footer">
                        <span>&copy; {currentYear} <a href="https://09labs.dev">09 labs</a></span>
                        <span>
                        Built with <a href="https://astro.build" target="_blank">Astro | React</a> ·
                        <a href="https://cloudflare.com" target="_blank">Cloudflare</a>
                        </span>
                  </footer>
            </div>
      </div>
</body>
</html>